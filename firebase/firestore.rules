rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function owns(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow get, create, update: if owns(uid)
        && request.resource.data.keys().hasOnly([
          'schema_version', 'display_name', 'preferences', 'consent', 'updated_at'
        ])
        && request.resource.data.schema_version == 1;
      allow list, delete: if false;

      match /events/{eventId} {
        allow create: if owns(uid)
          && request.resource.data.keys().hasOnly([
            'schema_version', 'event_type', 'created_at', 'platform', 'app_version',
            'encoding', 'payload', 'contains_source'
          ])
          && request.resource.data.schema_version == 1
          && request.resource.data.contains_source == false
          && request.resource.data.payload.size() <= 262144;
        allow get, list: if owns(uid);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
