{
  "build": {
    "beforeBuildCommand": "npm run build:bundle"
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/findex"],
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/findex": "binaries/findex"
        }
      },
      "rpm": {
        "files": {
          "/usr/bin/findex": "binaries/findex"
        }
      },
      "appimage": {
        "files": {
          "usr/bin/findex": "binaries/findex"
        }
      }
    },
    "windows": {
      "wix": {
        "fragmentPaths": ["windows/cli-path.wxs"],
        "componentRefs": ["FindexCliPath"]
      },
      "nsis": {
        "installerHooks": "windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2RDY2ODA2RTdCNzk4MDUKUldRRm1MZm5CbWpXRnF0NVhSdGwyak9vcmw0SG9yby9ScVZvOWN6RHp0Mkxlb1FvSE5oS0ZOYS8K",
      "endpoints": []
    }
  }
}
